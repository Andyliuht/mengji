# 复制为 .env 并填写

# ========== QQ 邮箱 - 找回密码 ==========
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务
# 2. 获取授权码（16位，非 QQ 密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASS=你的QQ邮箱授权码

# 找回密码邮件中的重置链接前缀（部署时改为实际前端地址）
# FRONTEND_URL=http://localhost:5173

# ========== AI 解梦 - 大模型配置 ==========
# 任选其一配置即可，未配置时使用规则匹配

# ========== 推荐：Ollama 完全免费 ==========
# 安装 https://ollama.com 后执行: ollama pull qwen2.5:7b
USE_OLLAMA=true
OLLAMA_MODEL=qwen2.5:7b

# ========== 或使用云 API（有免费额度）==========
# 通义千问 https://dashscope.aliyun.com
# DASHSCOPE_API_KEY=sk-xxx
# DASHSCOPE_MODEL=qwen-turbo

# 智谱 ChatGLM https://open.bigmodel.cn
# ZHIPU_API_KEY=xxx
# ZHIPU_MODEL=glm-4-flash

# ========== AI 配图 - 豆包 Seedream 文生图 ==========
# 火山方舟 https://console.volcengine.com/ark 创建推理接入点
# Doubao-Seedream-4.5 / 4.0 各有 200 张免费额度
# ARK_API_KEY=你的 API Key
# SEEDREAM_MODEL=你的推理接入点 ID（如 ep-2024xxxxxx）
