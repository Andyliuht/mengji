@startuml 状态图-梦境状态
!theme plain
skinparam backgroundColor #FEFEFE

title 状态图：梦境记录状态

[*] --> 草稿 : 创建梦境

state 草稿 {
  [*] --> 待完善
  待完善 --> 已保存 : 保存成功
}

草稿 --> 已保存 : 保存成功

state 已保存 {
  [*] --> 仅自己可见
}

已保存 --> 已分享 : 用户点击分享
已分享 --> 已保存 : 用户取消分享

state 已分享 {
  [*] --> 社区可见
  社区可见 : 可被浏览、评论、点赞
}

已保存 --> [*] : 用户删除
已分享 --> [*] : 用户删除/管理员下架

@enduml
